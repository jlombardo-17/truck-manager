# ─────────────────────────────────────────────────────────────────
# Truck Manager - Variables de entorno para PRODUCCIÓN (Docker)
#
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.production.example .env.production
#   2. Completar TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subir .env.production al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── Base de Datos ────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_DATABASE=truck_manager
DB_USERNAME=truck_user
DB_PASSWORD=<CAMBIAR: contraseña segura para el usuario DB>
DB_ROOT_PASSWORD=<CAMBIAR: contraseña root de MySQL — solo para docker-compose>

# ── JWT ──────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CAMBIAR: string aleatorio largo y seguro>
JWT_EXPIRES_IN=24h

# ── API / CORS ────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
# URL pública donde correrá el frontend (dominio o IP del servidor)
FRONTEND_URL=http://<TU_DOMINIO_O_IP>

# ── Dominio y SSL (para docker-compose.prod.yml) ─────────────────
# Dominio público donde correrá la app (sin https://, sin trailing slash)
DOMAIN=tudominio.com
# Email para notificaciones de Let's Encrypt (vencimiento de certs, etc.)
SSL_EMAIL=tu@email.com

# ── Mapas (opcional) ─────────────────────────────────────────────
# Si usas Mapbox: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# ── AWS S3 (opcional - para upload de archivos) ──────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
