# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=truck_manager

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# API
API_PORT=3000
NODE_ENV=development

# Dev seed user (solo desarrollo)
DEV_SEED_EMAIL=admin@truckmanager.local
DEV_SEED_PASSWORD=admin123
DEV_SEED_FIRST_NAME=Admin
DEV_SEED_LAST_NAME=Demo
DEV_SEED_ROLE=admin

# Mapas (opcional)
MAPBOX_TOKEN=your_mapbox_token_here

# Almacenamiento (opcional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name
